{
  "name": "opencode-registry",
  "version": "0.1.0",
  "description": "OpenCode Skills & MCP Registry — 标准化管理、查看、导入导出",
  "type": "module",
  "bin": {
    "oreg": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "cli": "node dist/cli/index.js",
    "scan": "node dist/cli/index.js scan",
    "list": "node dist/cli/index.js list",
    "mcp": "node dist/mcp-server/index.js",
    "start": "node dist/cli/index.js",
    "dashboard": "node dist/web/server.js",
    "scan-hermes": "OPENCODE_SKILL_DIRS=\"/mnt/d/ai-outputs/opencode-registry/hermes-exclusive/skills:opencode,/mnt/d/ai-outputs/opencode-registry/hermes-exclusive/plugins:opencode\" node dist/cli/index.js scan",
    "list-hermes": "node dist/cli/index.js list skill --category hermes",
    "list-hermes-plugins": "node dist/cli/index.js list skill --category hermes-plugin",
    "list-hermes-mcp": "node dist/cli/index.js list mcp --group hermes"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^11.7.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "fast-glob": "^3.3.0",
    "ora": "^8.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0"
  }
}
